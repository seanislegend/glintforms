{
    "name": "@glint/schemas",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    ".": "./src/index.ts",
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "lint": "biome lint .",

    },
    "dependencies": {
        "@glint/database": "workspace:*",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/node": "^22.10.2",
        "typescript": "^5.8.3",
        "vitest": "^2.1.9"
    }
}

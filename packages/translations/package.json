{
    "name": "@glint/translations",
    "version": "0.1.0",
    "description": "Deterministic CLI for extracting translatable strings from TypeScript/React code",
    "type": "module",
    "main": "./dist/runtime/index.js",
    "types": "./dist/runtime/index.d.ts",
    "bin": {
        "translation": "./dist/src/cli/index.js"
    },
    "exports": {
        ".": {
            "types": "./dist/src/runtime/index.d.ts",
            "default": "./dist/src/runtime/index.js"
        },
        "./runtime": {
            "types": "./dist/src/runtime/index.d.ts",
            "default": "./dist/src/runtime/index.js"
        },
        "./cli": {
            "types": "./dist/src/cli/index.d.ts",
            "default": "./dist/src/cli/index.js"
        },
        "./constants": {
            "types": "./dist/src/constants.d.ts",
            "default": "./dist/src/constants.js"
        },
        "./keys": {
            "types": "./locales/keys.ts",
            "default": "./locales/keys.ts"
        }
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "test": "bun test"
    },
    "dependencies": {
        "@babel/parser": "^7.23.0",
        "@babel/traverse": "^7.23.0",
        "@babel/types": "^7.23.0",
        "commander": "^11.1.0",
        "glob": "^10.3.0",
        "zod": "^3.22.0"
    },
    "devDependencies": {
        "@types/babel__traverse": "^7.20.0",
        "bun-types": "^1.0.0",
        "typescript": "^5.0.0"
    }
}


{
    "extends": "../../packages/tsconfig/nextjs.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": { "@/*": ["./src/*"] },
        "plugins": [{ "name": "next" }],
        "typeRoots": ["./node_modules/@types", "./src/types"],
        "strict": true,
        "strictNullChecks": true
    },
    "include": [
        "**/*.ts",
        "**/*.tsx",
        "../../types",
        "next-env.d.ts",
        "next.config.js",
        "tailwind.config.ts",
        ".next/types/**/*.ts",
        "trigger.config.ts"
    ],
    "exclude": ["node_modules", ".next"]
}

{
    "name": "glint",
    "version": "0.0.0",
    "devDependencies": {
        "@biomejs/biome": "^2.3.7",
        "@types/node": "^20.10.0",
        "dotenv": "^17.2.3",
        "turbo": "^2.6.1",
        "typescript": "^5.3.0"
    },
    "description": "An AI-assisted survey platform: Data points that shine, insights that catch the eye.",
    "packageManager": "bun@1.2.18",
    "private": true,
    "scripts": {
        "build": "turbo run build",
        "dev:api": "turbo run dev --filter=@glint/api",
        "start:api": "turbo run start --filter=@glint/api",
        "build:admin": "NODE_ENV=production turbo run build --filter=@glint/admin",
        "dev:admin": "NODE_ENV=development turbo run dev --filter=@glint/admin",
        "start:admin": "NODE_ENV=production turbo run start --filter=@glint/admin",
        "start:trigger": "turbo run start:trigger",
        "lint": "biome check --write",
        "format": "biome format --write",
        "type-check": "turbo run type-check",
        "db:generate": "turbo run db:generate",
        "db:migrate": "turbo run db:migrate",
        "db:seed": "turbo run db:seed",
        "db:studio": "turbo run db:studio",
        "types:generate": "turbo run types:generate",
        "test:e2e": "turbo run test:e2e",
        "test:run": "turbo run test:run"
    },
    "workspaces": ["apps/*", "packages/*"]
}
